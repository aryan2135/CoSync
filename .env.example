# Database
# Dev (SQLite):
DATABASE_URL="file:./db/custom.db"
# Prod (PostgreSQL):
# DATABASE_URL="postgresql://user:pass@host:5432/cosync"

# NextAuth
NEXTAUTH_SECRET="dev-secret-change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Collaboration service (port 3001)
COLLAB_PORT=3001
COLLAB_JWT_SECRET="dev-collab-secret-change-me"

# Internal server-to-server secret (collab → app persistence)
INTERNAL_SECRET="dev-internal-secret-change-me"

# AI provider — pluggable, single switch.
# Supported: zai | groq | google | openrouter | together | ollama | none
AI_PROVIDER=zai
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=

# Collaboration service host (used by collab service to reach the app)
APP_BASE=http://localhost:3000
