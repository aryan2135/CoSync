// CoSync — Local-First Collaborative Document Editor
// Schema is portable: SQLite in dev, PostgreSQL in prod (swap datasource provider + DATABASE_URL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Dev: sqlite. Prod: postgresql (set provider via env or swap here before `prisma migrate`).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// NextAuth.js tables (credential + JWT session, PrismaAdapter)
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    Membership[]
  ownedDocuments Document[]      @relation("OwnedDocuments")
  versions       DocumentVersion[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Application domain
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model Document {
  id            String   @id @default(cuid())
  title         String   @default("Untitled document")
  // Latest Yjs CRDT state snapshot (binary). Source of truth for late joiners.
  state         Bytes?
  // State vector for incremental sync handshakes.
  stateVector   Bytes?
  // Rendered plain-text preview for lists/search (denormalized).
  preview       String?
  wordCount     Int      @default(0)
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner      User          @relation("OwnedDocuments", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId    String
  members    Membership[]
  versions   DocumentVersion[]
  aiInsights AiInsight[]

  @@index([ownerId])
  @@index([updatedAt])
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  documentId String
  role       Role     @default(EDITOR)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([documentId])
  @@index([userId])
}

// Append-only version snapshots. Never mutated → safe time-travel.
model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  createdById String
  label       String?  // optional user label, e.g. "Pre-review draft"
  // Full Yjs state for restore.
  state       Bytes
  stateVector Bytes
  // Human-readable preview (plain text + lightweight HTML excerpt).
  contentText String
  contentHtml String
  wordCount   Int
  charCount   Int
  createdAt   DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model AiInsight {
  id         String   @id @default(cuid())
  documentId String
  type       String   // 'summary' | 'tags' | 'title' | 'improve' | 'qa'
  content    String   // result text (or JSON string for structured results)
  prompt     String?  // original prompt for traceability
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, type, createdAt])
  @@index([createdAt])
}
